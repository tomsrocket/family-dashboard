{
  "name": "Foto Upload",
  "short_name": "Upload",
  "start_url": "/upload/index.html",
  "display": "standalone",
  "icons": [
  {
    "src": "/upload/icon-192.png",
    "sizes": "192x192",
    "type": "image/png"
    }
  ],
  "share_target": {
    "action": "/upload/upload.php",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "files": [
        {
          "name": "file",
          "accept": ["image/*"]
        }
      ]
    }
  }
}